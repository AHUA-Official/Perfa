# LangChain Agent 配置文件示例
# 复制此文件为 .env 并填写实际值

# ==================== 智谱AI GLM配置 ====================
# 智谱AI API Key（从 https://open.bigmodel.cn 获取）
ZHIPU_API_KEY=your-zhipu-api-key-here

# 智谱AI模型名称
ZHIPU_MODEL=glm-5

# 智谱AI API基础URL
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 温度参数（0-1，越高越随机）
ZHIPU_TEMPERATURE=0.1

# 最大输出tokens
ZHIPU_MAX_TOKENS=4096

# ==================== MCP Server配置 ====================
# MCP Server地址
MCP_SERVER_URL=http://localhost:9000

# SSE端点
MCP_SSE_ENDPOINT=/sse

# 连接超时（秒）
MCP_CONNECT_TIMEOUT=30.0

# 读取超时（秒）
MCP_READ_TIMEOUT=300.0

# API Key（如果MCP Server需要认证，可选）
MCP_API_KEY=

# ==================== ChromaDB配置 ====================
# ChromaDB地址
CHROMADB_HOST=localhost

# ChromaDB端口
CHROMADB_PORT=8001

# 集合名称
CHROMADB_COLLECTION=perfa_history

# 持久化目录（可选）
CHROMADB_PERSIST_DIR=

# 搜索参数
CHROMADB_SEARCH_TOP_K=5
CHROMADB_SEARCH_THRESHOLD=0.7

# Embedding模型
CHROMADB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==================== Agent配置 ====================
# 最大迭代次数
AGENT_MAX_ITERATIONS=10

# 执行超时（秒）
AGENT_TIMEOUT=300.0

# 记忆最大轮数
AGENT_MEMORY_MAX_TURNS=10

# 记忆最大存活时间（小时）
AGENT_MEMORY_MAX_AGE=24

# 错误重试次数
AGENT_ERROR_MAX_RETRIES=3

# 重试延迟（秒）
AGENT_RETRY_DELAY=1.0

# ==================== 日志配置 ====================
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 日志文件路径（可选）
LOG_FILE=
